<div id="userForm" class="card-new" style="margin-bottom: 2rem;">
  <div class="card-header">
      <div class="card-title">New Driver</div>
  </div>
  <div class="card-body">
    <%= form_with(model: @user, url: create_driver_users_path) do |f|%>
      <% unless f.object.errors.empty? %>
        <ul class="list-group">
          <li class="list-group-item active">Driver Created Failed</li>
          <% f.object.errors.full_messages.each do |msg| %>
            <li class="list-group-item list-group-item-danger"><%= msg %></li>
          <% end -%>
        </ul>
      <% end -%>
      <div class="form-section" style="margin-bottom: 2rem;    margin-top: 2.5rem;">
        <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
          <div class="form-group">
              <label class="form-label">Login Name*</label>
              <%= f.text_field :nickname, class: "form-input", placeholder: "", required: true %>
          </div>
          <div class="form-group">
              <label class="form-label">Password*</label>
              <%= f.password_field :password, class: "form-input", placeholder: "", required: true %>
          </div>
          <div class="form-group">
              <label class="form-label">Password Confirmation*</label>
              <%= f.password_field :password_confirmation, class: "form-input", placeholder: "", required: true %>
          </div>
        </div>
      </div>
      <div class="form-section" style="margin-bottom: 2rem;    margin-top: 2.5rem;">
        <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
          <div class="form-group">
              <label class="form-label">Driver Name*</label>
              <%= f.text_field :user_name, class: "form-input", placeholder: "", required: true %>
          </div>
          <div class="form-group">
              <label class="form-label">ID Card</label>
              <%= f.text_field :id_card, class: "form-input", placeholder: "", required: false %>
          </div>
          <div class="form-group">
              <label class="form-label">Driver Phone</label>
              <%= f.phone_field :user_phone, class: "form-input", placeholder: "", required: false %>
          </div>
        </div>
      </div>
      <div class="form-section" style="margin-bottom: 2rem;    margin-top: 2.5rem;">
        <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
          <div class="form-group">
              <label class="form-label">Driver License*</label>
              <%= f.text_field :driver_license, class: "form-input", placeholder: "", required: true %>
          </div>
          <div class="form-group">
              <label class="form-label">License Type*</label>
              <%= f.select :license_type, ['3.5t','12t','18t'], {required: true}, {class: 'form-select'} %>
          </div>
          <div class="form-group">
              <label class="form-label">License Expire Date*</label>
              <%= f.text_field :license_expire_date, class: "datepicker form-input", placeholder: "", required: true %>
          </div>
        </div>
      </div>
      <div style="display: flex; justify-content: flex-end; gap: 1rem;">
          <button type="submit" class="btn btn-primary">Create Driver</button>
      </div>
    <% end %>
  </div>
</div>

<script type="text/javascript">
  $('.datepicker').datepicker({
    format: 'yyyy/mm/dd',
    startDate: '+0d',
    autoclose: true
  });
</script>